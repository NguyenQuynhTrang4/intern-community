# Database — matches docker-compose.yml defaults
DATABASE_URL="postgresql://td_user:td_password@localhost:5432/td_community"

# NextAuth
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# GitHub OAuth App — REQUIRED for authentication
# Setup guide: See GITHUB_OAUTH_SETUP.md
# Create app: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (local)
#               https://yourdomain.com/api/auth/callback/github (production)
AUTH_GITHUB_ID="your_github_client_id_here"
AUTH_GITHUB_SECRET="your_github_client_secret_here"
